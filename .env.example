# Database
DATABASE_URL="postgresql://user:password@localhost:5432/quadratic?schema=public"

# GitHub App
GITHUB_APP_ID="your-github-app-id"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET="your-webhook-secret"

# GitHub OAuth (via GitHub App)
GITHUB_CLIENT_ID="your-github-app-client-id"
GITHUB_CLIENT_SECRET="your-github-app-client-secret"
GITHUB_APP_SLUG="your-github-app-slug"

# Session
SESSION_SECRET="a-random-session-secret"

# Server
PORT=3000
BASE_URL="http://localhost:3000"

# OIDC token exchange (RFC 8693)
# The issuer of the incoming OIDC JWT (defaults to GitHub Actions OIDC).
OIDC_ISSUER="https://token.actions.githubusercontent.com"
# The audience this service expects in incoming OIDC JWTs.
OIDC_AUDIENCE="api://quadratic"
# Lifetime of issued access tokens, in seconds.
OIDC_TOKEN_LIFETIME_SECONDS=3600

# Logging
# One of: debug, info, warn, error. Defaults to "info".
LOG_LEVEL="info"
