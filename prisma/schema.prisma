generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int      @id @default(autoincrement())
  githubId        Int      @unique
  login           String
  name            String?
  avatarUrl       String?
  accessToken     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  issues          Issue[]
}

model Installation {
  id              Int      @id @default(autoincrement())
  githubInstallationId Int @unique
  accountLogin    String
  accountType     String   // "User" or "Organization"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  repositories    Repository[]
}

model Repository {
  id              Int          @id @default(autoincrement())
  githubId        Int          @unique
  fullName        String       @unique
  name            String
  owner           String
  installationId  Int
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  installation    Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  issues          Issue[]
  issuedTokens    IssuedToken[]

  @@index([installationId])
}

// Tokens issued via OIDC token exchange (RFC 8693). Each token grants
// scoped access to a single repository's issues. The raw token value is
// never stored; only a SHA-256 hash is persisted.
model IssuedToken {
  id              Int       @id @default(autoincrement())
  tokenHash       String    @unique
  scope           String
  repositoryId    Int
  agent           String?
  actor           String?
  actorId         String?
  subject         String?
  jti             String?   @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  repository      Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
  @@index([expiresAt])
}

model Issue {
  id              Int       @id @default(autoincrement())
  title           String
  description     String?
  status          IssueStatus @default(OPEN)
  repositoryId    Int
  authorId        Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  repository      Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  author          User       @relation(fields: [authorId], references: [id])

  @@index([repositoryId])
  @@index([authorId])
  @@index([status])
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}
